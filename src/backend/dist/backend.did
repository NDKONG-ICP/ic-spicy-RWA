   layer_combination: vec nat;
   nft_id: opt text;
   nft_standard: variant {
                   EXT;
                   Hedera;
                   ICRC37;
                 };
   owner: principal;
   rarity_tier: opt RarityTier;
   tier: MembershipTier;
 };
type LifecycleUpgradeEvent = 
