   redeemed: bool;
   redeemed_by: opt principal;
 };
type AssignAction = 
 variant {
   Airdrop: record {to: principal;};
   AssignToQR: record {claim_token: text;};
   ListOnShop: record {product_id: nat;};
 };
type ArtworkLayerId = nat;
type ArtworkLayer = 
 record {
   id: ArtworkLayerId;
   layer_number: nat;
   name: text;
   object_key: text;
   uploaded_at: Timestamp;
 };
type AirdropAssignment = 
 record {
   nftId: nat;
   recipient: principal;
 };
type AddWeatherRecordInput = 
 record {
   date: text;
   humidity: opt float64;
   latitude: float64;
   longitude: float64;
   precipitation: float64;
   temperature_max: float64;
   temperature_min: float64;
   wind_speed: opt float64;
 };
type AddFeedingInput = 
 record {
   date: Timestamp;
   dosage_amount: text;
   notes: opt text;
   nutrient_type: text;
   plant_id: PlantId;
   product_name: text;
 };
service : {
  _immutableObjectStorageCreateCertificate: (hash: text) -> (blob);
  _immutableObjectStorageGetCertificate: () -> (opt blob) query;
  _initializeAccessControl: () -> ();
  acceptOffer: (offerId: text) -> (Offer);
  addArtworkLayer: (name: text, object_key: text, layer_number: nat) ->
   (ArtworkLayer);
  addFeedingRecord: (input: AddFeedingInput) -> (FeedingPublic);
  addPlantPhoto: (plant_id: PlantId, photo_key: text) -> ();
  addWeatherRecord: (input: AddWeatherRecordInput) -> (WeatherRecord);
  adminSubmitToDAB: (collectionName: text, collectionDescription: text,
   standard: text, canisterIdOverride: opt text) ->
   (variant {
      err: text;
      ok: text;
    });
  airdropNFT: (token_id: text, recipient: principal) -> ();
  assignCallerUserRole: (user: principal, role: UserRole) -> ();
  assignPoolNFT: (nftId: nat, action: AssignAction) -> ();
  batchAirdropFromPool: (assignments: vec AirdropAssignment) ->
   (record {
      failed: nat;
      succeeded: nat;
    });
  batchAssignPoolNFTs: (nftIds: vec nat, action: AssignAction) -> (nat);
  batchAssignToQR: (nftIds: vec nat) -> (vec QRAssignmentResult);
  batchListOnShop: (assignments: vec ShopAssignment) ->
   (record {
      failed: nat;
      succeeded: nat;
    });
  batchMintFoundersCollection: (entries: vec FoundersMintInput) ->
   (vec FoundersMintResult);
  beginArtworkUpload: (totalChunks: nat) -> ();
  buyResaleListing: (listing_id: text) -> (variant {
                                             err: text;
                                             ok;
                                           });
  cancelOffer: (offerId: text) -> (Offer);
  cancelResaleListing: (listing_id: text) -> (variant {
                                                err: text;
                                                ok;
                                              });
  clearArtworkFiles: () -> ();
  counterOffer: (input: CounterOfferInput) -> (Offer);
  createBatchGiftPack: (plant_ids: vec PlantId) ->
   (variant {
      err: text;
      ok: BatchGiftPackPublic;
    });
  createComment: (input: CreateCommentInput) -> (CommentPublic);
  createDAOProposal: (input: CreateProposalInput) -> (ProposalPublic);
  createOrder: (buyer: principal, input: CreateOrderInput) -> (OrderPublic);
  createPlant: (input: CreatePlantInput) -> (PlantPublic);
  createPost: (input: CreatePostInput) -> (PostPublic);
  createProduct: (input: CreateProductInput) -> (ProductPublic);
  createRecipe: (input: CreateRecipeInput) -> (Recipe);
  createTray: (input: CreateTrayInput) -> (TrayPublic);
  dabTransform: (input: TransformationInput) -> (TransformationOutput) query;
  deleteProduct: (product_id: ProductId) -> ();
  deleteRecipe: (id: RecipeId) -> (bool);
  deleteTray: (tray_id: TrayId) -> ();
  finalizeArtworkUpload: () -> (UploadResult);
  followUser: (target: principal) -> ();
  generateAllPoolNFTs: () -> (nat);
  generateClaimToken: (plant_id: PlantId, rarity_tier: RarityTier) ->
   (ClaimTokenPublic);
  generatePickupQRPayload: (plant_id: PlantId) -> (text) query;
  getActiveResaleListings: () -> (vec ResaleListingPublic) query;
  getAdminPrincipal: () -> (text) query;
  getArtworkFile: (path: text) -> (opt vec nat8);
  getArtworkUploadResult: () -> (UploadResult) query;
  getArtworkUploadStatus: () -> (UploadSessionStatus) query;
  getBatchGiftPack: (claim_token_id: ClaimTokenId) ->
   (opt BatchGiftPackPublic) query;
  getCallerMembership: () -> (opt MembershipNFTPublic) query;
  getCallerUserProfile: () -> (opt UserProfilePublic) query;
  getCallerUserRole: () -> (UserRole) query;
  getCanisterId: () -> (text) query;
  getClaimToken: (token_id: ClaimTokenId) -> (opt ClaimTokenPublic) query;
  getDAOProposal: (proposal_id: ProposalId) -> (opt ProposalPublic) query;
  getDAOStats: () ->
   (record {
      activeProposals: nat;
      totalProposals: nat;
      totalVotes: nat;
    }) query;
  getFollowersCount: (user: principal) -> (nat) query;
  getFollowingCount: (user: principal) -> (nat) query;
  getForSalePlants: () -> (vec PlantPublic) query;
  getMembershipPriceInToken: (token: OracleToken) -> (nat) query;
  getMyOffers: () -> (vec Offer) query;
  getMyResaleListings: () -> (vec ResaleListingPublic) query;
  getMySchedules: () -> (vec SavedSchedule);
  getMyWeatherRecords: (limit: nat) -> (vec WeatherRecord);
  getOffer: (offerId: text) -> (opt Offer) query;
  getOffersForNft: (nftId: text) -> (vec Offer) query;
  getOffersReceived: () -> (vec Offer) query;
  getOrder: (order_id: OrderId) -> (opt OrderPublic) query;
  getPlant: (plant_id: PlantId) -> (opt PlantPublic) query;
  getPlantTimeline: (plant_id: PlantId) -> (opt PlantTimeline) query;
  getPoolDashboard: () -> (PoolDashboard);
  getPoolNFT: (nftId: nat) -> (opt PoolNFTPublic) query;
  getPoolNFTs: (filter: opt PoolNFTStatus__1, offset: nat, limit: nat) ->
   (vec PoolNFTPublic__1) query;
  getPoolStats: () -> (PoolStats) query;
  getProduct: (product_id: ProductId) -> (opt ProductPublic) query;
  getPublicProfile: (user: principal) -> (opt UserProfilePublic) query;
  getRecipe: (id: RecipeId) -> (opt Recipe) query;
  getScheduleByShareToken: (share_token: text) -> (opt SavedSchedule) query;
  getScheduleData: (stage: text, inputs: vec text) ->
   (vec ScheduleEntry) query;
  getTokenPriceInIcp: (token: OracleToken) -> (nat) query;
  getTokenPrices: () -> (vec TokenPrice) query;
  getTray: (tray_id: TrayId) -> (opt TrayPublic) query;
  getTreasuryBalance: (token: TreasuryToken) -> (nat) query;
  getTreasuryBalances: () -> (vec TreasuryBalance) query;
  getTreasuryLedger: () -> (vec TreasuryTransaction) query;
  getUpgradeHistory: (plant_id: PlantId) -> (vec LifecycleUpgradeEvent) query;
  getUserPosts: (user: principal) -> (vec PostPublic) query;
  getWalletAddress: () -> (text) query;
  getWalletBalances: () -> (vec WalletToken);
  getWalletTransactions: () -> (vec WalletTransaction) query;
  hasDAOAccess: () -> (bool) query;
  hasMembership: () -> (bool) query;
  isCallerAdmin: () -> (bool) query;
  issueMembership: (owner: principal, tier: MembershipTier, nft_standard:
   variant {
     EXT;
     Hedera;
     ICRC37;
   }) -> (MembershipNFTPublic);
  likePost: (post_id: PostId) -> (nat);
  listArtworkFiles: () -> (vec record {
                                 text;
                                 nat;
                               }) query;
  listArtworkLayers: () -> (vec ArtworkLayer);
  listCommentsByPost: (post_id: PostId) -> (vec CommentPublic) query;
  listDAOProposals: () -> (vec ProposalPublic) query;
  listMyPlants: () -> (vec PlantPublic);
  listNFTForResale: (plant_id: PlantId, price_icp: float64) ->
   (variant {
      err: text;
      ok: ResaleListingPublic;
    });
  listOrdersByBuyer: () -> (vec OrderPublic) query;
  listPlants: () -> (vec PlantPublic) query;
  listPlantsByStage: (stage: PlantStage) -> (vec PlantPublic) query;
  listPoolNFTs: (statusFilter: opt PoolNFTStatus, limit: nat) ->
   (vec PoolNFTPublic);
  listPosts: () -> (vec PostPublic) query;
  listProducts: () -> (vec ProductPublic) query;
  listProductsByCategory: (category: ProductCategory) ->
   (vec ProductPublic) query;
  listRecipes: () -> (vec Recipe) query;
  listTrays: () -> (vec TrayPublic) query;
  markPlantGerminated: (plant_id: PlantId, germination_date: Timestamp) -> ();
  mintEXT: (plantId: nat, imageKey: text, attributes:
   vec record {
         text;
         text;
       }) -> (text);
  mintHederaNFT: (plant_id: PlantId, image_key: opt text, attributes:
   vec record {
         text;
         text;
       }) -> (text);
  mintICRC37: (plant_id: PlantId, image_key: opt text, attributes:
   vec record {
         text;
         text;
       }) -> (text);
  mintRWAProvenance: (input: MintRWAProvenanceInput) -> (text);
  placeOrder: (input: CreateOrderInput) -> (OrderPublic);
  preGenerateNFTPool: (layerCount: nat, layerFileCounts: vec nat) ->
   (record {
      ok: bool;
      total: nat;
    });
  priceOracleTransform: (input: TransformationInput) ->
   (TransformationOutput) query;
  redeemBatchClaim: (token_id: ClaimTokenId) ->
   (variant {
      err: text;
      ok: BatchGiftPackPublic;
    });
  redeemClaim: (token_id: ClaimTokenId) -> (ClaimTokenPublic);
  refreshTokenPrices: () -> (bool);
  rejectOffer: (offerId: text) -> (Offer);
  removePlantPhoto: (plant_id: PlantId, photo_key: text) -> ();
  resetOrphanPoolNFT: (nftId: nat) -> (bool);
  resetPoolNFT: (nftId: nat) -> (variant {
                                   err: text;
                                   ok: text;
                                 });
  saveCallerUserProfile: (input: SaveProfileInput) -> ();
  saveSchedule: (stage: text, inputs: vec text) -> (ScheduleId);
  seedDefaultRecipes: () -> ();
  sendToken: (input: SendTokenInput) -> (variant {
                                           err: text;
                                           ok: text;
                                         });
  setForSale: (plant_id: PlantId, for_sale: bool) -> ();
  setPlantNFT: (plant_id: PlantId, nft_id: text) -> ();
  storeArtworkFile: (path: text, data: vec nat8, mimeType: text) ->
   (StoredFile);
  submitOffer: (input: SubmitOfferInput) -> (Offer);
  toggleCooked: (plant_id: PlantId) -> ();
  toggleRecipeFeatured: (id: RecipeId) -> (opt Recipe);
  transform: (input: TransformationInput) -> (TransformationOutput) query;
  transplantCell: (input: TransplantInput) -> (PlantPublic);
  treasuryDeposit: (token: TreasuryToken, amount: nat, memo: opt text) ->
   (TreasuryTransaction);
  treasuryTransfer: (token: TreasuryToken, amount: nat, from: principal, to:
   principal, memo: opt text) -> (TreasuryTransaction);
  treasuryWithdraw: (token: TreasuryToken, amount: nat, to: principal, memo:
   opt text) -> (TreasuryTransaction);
  triggerLifecycleUpgrade: (plant_id: PlantId, new_stage: text) -> (text);
  unfollowUser: (target: principal) -> ();
  unlikePost: (post_id: PostId) -> (nat);
  updateCellData: (input: UpdateCellDataInput) -> ();
  updateOrderStatus: (order_id: OrderId, status: OrderStatus) -> ();
  updatePlantMetadata: (input: UpdatePlantMetadataInput) -> ();
  updatePlantStage: (plant_id: PlantId, new_stage: PlantStage, notes:
   text) -> ();
  updateProduct: (input: UpdateProductInput) -> ();
  updateRecipe: (input: UpdateRecipeInput) -> (opt Recipe);
  updateTrayName: (tray_id: TrayId, new_name: text) -> ();
  uploadArtworkChunk: (chunkIndex: nat, totalChunks: nat, data: vec nat8) ->
   (variant {
      err: text;
      ok;
    });
  voteOnProposal: (proposal_id: ProposalId, option_index: nat) -> ();
}
