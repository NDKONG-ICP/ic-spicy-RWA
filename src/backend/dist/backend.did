 };
type OrderItem = 
 record {
   plant_id: opt PlantId;
   price_cents: nat;
   product_id: ProductId;
   quantity: nat;
 };
type OrderId = nat;
type OracleToken = 
 variant {
   ICP;
   ckBTC;
   ckETH;
   ckUSDC;
   ckUSDT;
 };
type OfferToken = 
 variant {
   ICP;
   ckBTC;
   ckETH;
   ckUSDC;
   ckUSDT;
 };
type OfferStatus = 
 variant {
   Accepted;
   Cancelled;
   Countered;
   Pending;
   Rejected;
 };
type OfferHistoryEntry = 
 record {
   action: OfferAction;
   amount: nat;
   by: principal;
   timestamp: Timestamp;
   token: OfferToken;
 };
type OfferAction = 
 variant {
   Accepted;
   Cancelled;
   Countered;
   Rejected;
   Submitted;
 };
type Offer = 
 record {
   buyer: principal;
   created_at: Timestamp;
   history: vec OfferHistoryEntry;
   icp_equivalent: nat;
   id: text;
   nft_id: text;
   offered_amount: nat;
   offered_token: OfferToken;
   seller: principal;
   status: OfferStatus;
   updated_at: Timestamp;
 };
type NFTStandard = 
 variant {
   EXT;
   Hedera;
   ICRC37;
 };
type MintRWAProvenanceInput = 
 record {
   artwork_layer_id: ArtworkLayerId;
   custom_notes: text;
   plant_id: PlantId;
   rarity_tier: nat;
 };
type MembershipTier = 
 variant {
   Premium;
   Standard;
 };
type MembershipNFTPublic = 
