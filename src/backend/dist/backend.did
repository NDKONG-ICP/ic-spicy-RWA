 };
type TxType = 
 variant {
   receive;
   send;
 };
type TxStatus = 
 variant {
   completed;
   failed;
   pending;
 };
type TreasuryTxType = 
 variant {
   Deposit;
   OfferSettlement;
   Transfer;
   Withdrawal;
 };
type TreasuryTransaction = 
 record {
   amount_e8s: nat;
   from_principal: opt principal;
   id: text;
   memo: opt text;
   offer_id: opt text;
   timestamp: Timestamp;
   to_principal: opt principal;
   token: TreasuryToken;
   tx_type: TreasuryTxType;
 };
type TreasuryToken = 
 variant {
   ICP;
   ckBTC;
   ckETH;
   ckUSDC;
   ckUSDT;
 };
type TreasuryBalance = 
 record {
   balance_e8s: nat;
   token: TreasuryToken;
 };
type TrayPublic = 
