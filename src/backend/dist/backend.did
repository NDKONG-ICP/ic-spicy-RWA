type http_request_result = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type http_header = 
 record {
   name: text;
   value: text;
 };
type WeatherRecordId = nat;
type WeatherRecord = 
 record {
   date: text;
   humidity: opt float64;
   id: WeatherRecordId;
   latitude: float64;
   longitude: float64;
   precipitation: float64;
   recorded_at: Timestamp;
   temperature_max: float64;
   temperature_min: float64;
   user: principal;
   wind_speed: opt float64;
 };
type WalletTransaction = 
 record {
   amount: nat;
   counterparty: text;
   id: text;
   status: TxStatus;
   timestamp: Timestamp;
   tokenSymbol: text;
   txType: TxType;
 };
type WalletToken = 
 record {
   balance: nat;
   decimals: nat8;
   name: text;
   symbol: text;
   usdValue: float64;
 };
type UserRole = 
 variant {
   admin;
   guest;
   user;
 };
type UserProfilePublic = 
 record {
   avatar_key: opt text;
   bio: text;
   created_at: Timestamp;
   follower_count: nat;
   following_count: nat;
   principal_id: principal;
   username: text;
 };
type UploadSessionStatus = 
 record {
   received: nat;
   started_at: Timestamp;
   total_chunks: nat;
 };
type UploadResult = 
 record {
   asset_canister_id: text;
   layer_summaries: vec LayerSummary;
   layers_detected: nat;
   total_files: nat;
 };
type UpdateRecipeInput = 
 record {
   application_notes: opt text;
   description: opt text;
   full_name: opt text;
   id: RecipeId;
   ingredients: opt vec text;
   instructions: opt vec text;
   is_featured: opt bool;
   name: opt text;
   photo_key: opt text;
   shop_link: opt text;
   shop_link_label: opt text;
   tags: opt vec text;
 };
type UpdateProductInput = 
 record {
   active: opt bool;
   description: opt text;
   image_key: opt text;
   name: opt text;
   price_cents: opt nat;
   product_id: ProductId;
 };
type UpdatePlantMetadataInput = 
 record {
   genetics: opt text;
