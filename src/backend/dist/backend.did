                    common: nat;
                    rare: nat;
                    uncommon: nat;
                  };
 };
type PoolNFTStatus__1 = 
 variant {
   Airdropped;
   QRAssigned;
   Ready;
   Shop;
 };
type PoolNFTStatus = 
 variant {
   Airdropped: record {
                 at: Timestamp;
                 to: principal;
               };
   AssignedToQR: record {
                   at: Timestamp;
                   claim_token: text;
                 };
   ListedOnShop: record {
                   at: Timestamp;
                   product_id: nat;
                 };
   Ready;
 };
type PoolNFTRarity = 
 variant {
   Common;
   Rare;
   Uncommon;
 };
type PoolNFTPublic__1 = 
 record {
   assignedAt: opt Timestamp;
   assignedTo: opt principal;
   claimTokenId: opt text;
   compositeImageKey: text;
   id: nat;
   layerCombination: vec nat;
   rarityTier: RarityTier;
